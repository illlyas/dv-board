      "unit": "件"
    },
    "p0.kpi.gen_day": {
      "title": "日产量",
      "subtitle": "当日累计生产总量",
      "unit": "件"
    },
    "p0.chart.hours_trend": {
      "title": "产量趋势",
      "subtitle": "当日每小时实际产量与计划产量对比",
      "xAxis": {
        "field": "hour",
        "label": "时间"
      },
      "yAxis": [
        {
          "field": "actual",
          "label": "实际产量"
        },
        {
          "field": "plan",
          "label": "计划产量"
        }
      ]
    },
    "p0.kpi.capacity_rate": {
      "title": "产能利用率",
