  "chartPalette": ["#22D3EE", "#38BDF8", "#818CF8", "#34D399", "#FACC15", "#F87171"],
  "raw": {
    "color": {
      "primary": { "name": "霓虹青蓝", "hex": "#22D3EE", "usage": "主数据线、指挥舱强调" },
      "secondary": [
        { "name": "主色悬停", "hex": "#67E8F9", "usage": "交互高亮" },
        { "name": "靛蓝辅色", "hex": "#818CF8", "usage": "次级系列" },
        { "name": "琥珀金", "hex": "#D49A48", "usage": "金属高亮、环形" }
      ],
      "accent": [],
      "surface": [
        { "name": "主背景", "hex": "#050814", "usage": "整屏最深底" },
        { "name": "模块衬底", "hex": "#0B1220", "usage": "顶栏、侧栏" },
        { "name": "次级表面", "hex": "#111B2E", "usage": "选中模块" },
        { "name": "弱衬", "hex": "#1E293B", "usage": "分割、弱底" }
      ],
      "text": [
        { "name": "主文案", "hex": "#F1F5F9", "usage": "标题、数值" },
        { "name": "次级文案", "hex": "rgba(241,245,249,0.72)", "usage": "次要文字" },
        { "name": "弱化文案", "hex": "rgba(241,245,249,0.42)", "usage": "辅助" },
        { "name": "反色文案", "hex": "#020617", "usage": "主色按钮上" }
      ],
      "border": [
        { "name": "边框", "hex": "rgba(148,163,184,0.25)", "usage": "模块分割" },
        { "name": "强边框", "hex": "rgba(34,211,238,0.45)", "usage": "霓虹勾边" }
      ],
      "semantic": {
        "success": { "name": "成功", "hex": "#22C55E", "usage": "正向" },
        "warning": { "name": "警告", "hex": "#FACC15", "usage": "预警" },
        "danger": { "name": "危险", "hex": "#F87171", "usage": "异常" },
        "info": { "name": "信息", "hex": "#60A5FA", "usage": "提示" },
        "grid": { "name": "网格", "hex": "rgba(34,211,238,0.12)", "usage": "图表网格" }
      }
    },
    "typography": {
      "fontFamily": {
        "display": "\"DIN Alternate\",\"Roboto Condensed\",system-ui,sans-serif",
        "body": "system-ui,\"Segoe UI\",\"PingFang SC\",sans-serif",
        "mono": "ui-monospace,\"JetBrains Mono\",\"Fira Code\",monospace"
      },
      "scale": [
        { "size": "12px", "usage": "xs" },
        { "size": "14px", "usage": "sm" },
        { "size": "16px", "usage": "md" },
        { "size": "18px", "usage": "lg" },
        { "size": "22px", "usage": "xl" },
        { "size": "28px", "usage": "2xl" },
        { "size": "34px", "usage": "3xl" }
      ],
      "weights": [
        { "weight": 400, "name": "regular" },
        { "weight": 500, "name": "medium" },
        { "weight": 600, "name": "semibold" },
        { "weight": 700, "name": "bold" }
      ]
    },
    "spacing": { "baseUnit": "8px", "scale": ["8px", "12px", "16px", "24px", "32px", "48px", "64px", "96px", "128px"] },
    "radius": { "sm": "4px", "md": "6px", "lg": "8px", "xl": "12px", "pill": "9999px" },
    "shadow": {
      "sm": "0 0 2px rgba(34,211,238,0.4)",
      "md": "0 0 6px rgba(34,211,238,0.35)",
      "lg": "0 0 12px rgba(34,211,238,0.45)",
      "xl": "0 0 20px rgba(34,211,238,0.55)"
    },
    "motion": { "fast": "150ms", "normal": "200ms", "slow": "240ms", "easing": "ease-out" },
    "components": {
      "button": { "background": "var(--color-surface-2)", "border": "var(--color-border)", "active": "var(--color-primary)" },
      "card": { "background": "var(--color-surface)", "border": "var(--color-border)", "radius": "var(--radius-lg)" },
      "input": { "background": "var(--color-surface-2)", "border": "var(--color-border-strong)", "focus": "var(--color-primary)" },
      "navigation": { "tab": "描边+主色选中" }
    }
  }
}
