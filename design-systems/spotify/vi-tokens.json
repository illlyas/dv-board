{
  "mode": "dark",
  "cssVariables": {
    "--color-bg": "#121212",
    "--color-surface": "#181818",
    "--color-surface-2": "#1F1F1F",
    "--color-muted": "#272727",
    "--color-primary": "#1ED760",
    "--color-primary-hover": "#4ADE80",
    "--color-accent": "#2DD4BF",
    "--color-accent-gold": "#D4AF5C",
    "--color-success": "#22C55E",
    "--color-warning": "#FACC15",
    "--color-danger": "#F87171",
    "--color-info": "#38BDF8",
    "--color-text-primary": "#FFFFFF",
    "--color-text-secondary": "rgba(255,255,255,0.72)",
    "--color-text-muted": "rgba(255,255,255,0.42)",
    "--color-text-inverse": "#121212",
    "--color-border": "rgba(30,215,96,0.22)",
    "--color-border-strong": "rgba(30,215,96,0.55)",
    "--color-grid": "rgba(30,215,96,0.08)",
    "--color-overlay": "rgba(0,0,0,0.65)",
    "--font-display": "\"SpotifyMixUITitle\",\"CircularSp-Arab\",\"Helvetica Neue\",Helvetica,system-ui,sans-serif",
    "--font-body": "\"SpotifyMixUI\",\"CircularSp-Arab\",\"Helvetica Neue\",Helvetica,system-ui,sans-serif",
    "--font-mono": "ui-monospace,\"JetBrains Mono\",\"Fira Code\",monospace",
    "--font-size-xs": "12px",
    "--font-size-sm": "14px",
    "--font-size-md": "16px",
    "--font-size-lg": "18px",
    "--font-size-xl": "22px",
    "--font-size-2xl": "28px",
    "--font-size-3xl": "34px",
    "--font-weight-regular": "400",
    "--font-weight-medium": "500",
    "--font-weight-semibold": "600",
    "--font-weight-bold": "700",
    "--line-height-tight": "1.15",
    "--line-height-normal": "1.45",
    "--line-height-relaxed": "1.55",
    "--letter-spacing-tight": "-0.01em",
    "--letter-spacing-normal": "0",
    "--letter-spacing-wide": "0.08em",
    "--space-1": "8px",
    "--space-2": "12px",
    "--space-3": "16px",
    "--space-4": "24px",
    "--space-5": "32px",
    "--space-6": "48px",
    "--space-8": "64px",
    "--space-10": "96px",
    "--space-12": "128px",
    "--radius-sm": "4px",
    "--radius-md": "8px",
    "--radius-lg": "12px",
    "--radius-xl": "16px",
    "--radius-pill": "9999px",
    "--shadow-sm": "0 0 2px rgba(30,215,96,0.35)",
    "--shadow-md": "0 8px 8px rgba(0,0,0,0.3)",
    "--shadow-lg": "0 8px 24px rgba(0,0,0,0.5)",
    "--shadow-xl": "0 12px 32px rgba(0,0,0,0.55)",
    "--motion-fast": "150ms",
    "--motion-normal": "200ms",
    "--motion-slow": "240ms",
    "--motion-easing": "ease-out",
    "--border-width-thin": "1px",
    "--border-width-normal": "2px",
    "--backdrop-blur": "0px",
    "--dv-chart-panel-bg": "transparent",
    "--dv-chart-panel-padding": "0",
    "--dv-chart-panel-border": "none",
    "--dv-chart-panel-radius": "0",
    "--dv-chart-plot-bg": "color-mix(in srgb, var(--color-text-primary) 15%, transparent)",
    "--dv-chart-grid-stroke": "rgba(30,215,96,0.1)",
    "--dv-chart-grid-dash": "2 8",
    "--dv-chart-axis-line": "#4D4D4D",
    "--dv-chart-axis-tick-stroke": "#4D4D4D",
    "--dv-chart-tick-label": "#B3B3B3",
    "--dv-chart-axis-title": "#FFFFFF",
    "--dv-chart-legend-text": "#B3B3B3",
    "--dv-chart-legend-inactive": "rgba(179,179,179,0.35)",
    "--dv-chart-tooltip-bg": "#181818",
    "--dv-chart-tooltip-border": "rgba(30,215,96,0.5)",
    "--dv-chart-tooltip-fg": "#FFFFFF",
    "--dv-chart-label-line": "rgba(179,179,179,0.5)",
    "--dv-chart-reference-stroke": "#FACC15",
    "--kpi-bg-from": "#121212",
    "--kpi-bg-to": "#1F1F1F",
    "--kpi-text-primary": "#FFFFFF",
    "--kpi-text-secondary": "rgba(255,255,255,0.72)",
    "--kpi-text-muted": "rgba(255,255,255,0.42)",
    "--kpi-glow-base": "var(--color-primary)"
  },
  "chartPalette": ["#1ED760", "#2DD4BF", "#22C55E", "#38BDF8", "#FACC15", "#F87171"],
  "raw": {
    "color": {
      "primary": { "name": "Spotify Green", "hex": "#1ED760", "usage": "播放、CTA、主数据" },
      "secondary": [
        { "name": "主色悬停", "hex": "#4ADE80", "usage": "悬停" },
        { "name": "青绿辅色", "hex": "#2DD4BF", "usage": "次级系列" },
        { "name": "暖金", "hex": "#D4AF5C", "usage": "金属高亮" }
      ],
      "accent": [],
      "surface": [
        { "name": "Near Black", "hex": "#121212", "usage": "最深底" },
        { "name": "Dark Surface", "hex": "#181818", "usage": "卡片" },
        { "name": "Mid Dark", "hex": "#1F1F1F", "usage": "交互面" },
        { "name": "弱衬", "hex": "#272727", "usage": "分割" }
      ],
      "text": [
        { "name": "主文案", "hex": "#FFFFFF", "usage": "主字" },
        { "name": "次级", "hex": "rgba(255,255,255,0.72)", "usage": "次要" },
        { "name": "弱化", "hex": "rgba(255,255,255,0.42)", "usage": "辅助" },
        { "name": "反色", "hex": "#121212", "usage": "主色按钮" }
      ],
      "border": [
        { "name": "边框", "hex": "rgba(30,215,96,0.22)", "usage": "分割" },
        { "name": "强边框", "hex": "rgba(30,215,96,0.55)", "usage": "强调" }
      ],
      "semantic": {
        "success": { "name": "成功", "hex": "#22C55E", "usage": "正向" },
        "warning": { "name": "警告", "hex": "#FACC15", "usage": "预警" },
        "danger": { "name": "危险", "hex": "#F87171", "usage": "负向" },
        "info": { "name": "信息", "hex": "#38BDF8", "usage": "公告蓝系" },
        "grid": { "name": "网格", "hex": "rgba(30,215,96,0.08)", "usage": "图表" }
      }
    },
    "typography": {
      "fontFamily": {
        "display": "\"SpotifyMixUITitle\",\"CircularSp-Arab\",\"Helvetica Neue\",Helvetica,system-ui,sans-serif",
        "body": "\"SpotifyMixUI\",\"CircularSp-Arab\",\"Helvetica Neue\",Helvetica,system-ui,sans-serif",
        "mono": "ui-monospace,\"JetBrains Mono\",\"Fira Code\",monospace"
      },
      "scale": [
        { "size": "12px", "usage": "xs" },
        { "size": "14px", "usage": "sm" },
        { "size": "16px", "usage": "md" },
        { "size": "18px", "usage": "lg" },
        { "size": "22px", "usage": "xl" },
        { "size": "28px", "usage": "2xl" },
        { "size": "34px", "usage": "3xl" }
      ],
      "weights": [
        { "weight": 400, "name": "regular" },
        { "weight": 500, "name": "medium" },
        { "weight": 600, "name": "semibold" },
        { "weight": 700, "name": "bold" }
      ]
    },
    "spacing": { "baseUnit": "8px", "scale": ["8px", "12px", "16px", "24px", "32px", "48px", "64px", "96px", "128px"] },
    "radius": { "sm": "4px", "md": "8px", "lg": "12px", "xl": "16px", "pill": "9999px" },
    "shadow": {
      "sm": "0 0 2px rgba(30,215,96,0.35)",
      "md": "0 8px 8px rgba(0,0,0,0.3)",
      "lg": "0 8px 24px rgba(0,0,0,0.5)",
      "xl": "0 12px 32px rgba(0,0,0,0.55)"
    },
    "motion": { "fast": "150ms", "normal": "200ms", "slow": "240ms", "easing": "ease-out" },
    "components": {
      "button": { "background": "var(--color-surface-2)", "border": "var(--color-border)", "active": "var(--color-primary)" },
      "card": { "background": "var(--color-surface)", "border": "var(--color-border)", "radius": "var(--radius-pill)" },
      "input": { "background": "var(--color-surface-2)", "border": "var(--color-border-strong)", "focus": "var(--color-primary)" },
      "navigation": { "tab": "Pill 导航" }
    }
  }
}
