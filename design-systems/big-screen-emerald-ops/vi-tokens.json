{
  "mode": "dark",
  "cssVariables": {
    "--color-bg": "#030712",
    "--color-surface": "#0B1F14",
    "--color-surface-2": "#132A1F",
    "--color-muted": "#1F3D2E",
    "--color-primary": "#4ADE80",
    "--color-primary-hover": "#86EFAC",
    "--color-accent": "#2DD4BF",
    "--color-accent-gold": "#D4A855",
    "--color-success": "#22C55E",
    "--color-warning": "#FACC15",
    "--color-danger": "#F87171",
    "--color-info": "#38BDF8",
    "--color-text-primary": "#ECFDF5",
    "--color-text-secondary": "rgba(236,253,245,0.72)",
    "--color-text-muted": "rgba(236,253,245,0.42)",
    "--color-text-inverse": "#030712",
    "--color-border": "rgba(74,222,128,0.22)",
    "--color-border-strong": "rgba(74,222,128,0.55)",
    "--color-grid": "rgba(74,222,128,0.06)",
    "--color-overlay": "rgba(0,0,0,0.65)",
    "--font-display": "\"Rajdhani\",\"Bahnschrift\",\"DIN Alternate\",system-ui,sans-serif",
    "--font-body": "system-ui,\"Segoe UI\",\"PingFang SC\",sans-serif",
    "--font-mono": "ui-monospace,\"JetBrains Mono\",\"Fira Code\",monospace",
    "--font-size-xs": "12px",
    "--font-size-sm": "14px",
    "--font-size-md": "16px",
    "--font-size-lg": "18px",
    "--font-size-xl": "22px",
    "--font-size-2xl": "28px",
    "--font-size-3xl": "34px",
    "--font-weight-regular": "400",
    "--font-weight-medium": "500",
    "--font-weight-semibold": "600",
    "--font-weight-bold": "700",
    "--line-height-tight": "1.15",
    "--line-height-normal": "1.45",
    "--line-height-relaxed": "1.55",
    "--letter-spacing-tight": "-0.01em",
    "--letter-spacing-normal": "0",
    "--letter-spacing-wide": "0.08em",
    "--space-1": "8px",
    "--space-2": "12px",
