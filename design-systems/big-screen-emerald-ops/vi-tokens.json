    "--radius-lg": "8px",
    "--radius-xl": "12px",
    "--radius-pill": "9999px",
    "--shadow-sm": "0 0 2px rgba(74,222,128,0.4)",
    "--shadow-md": "0 0 6px rgba(74,222,128,0.35)",
    "--shadow-lg": "0 0 12px rgba(74,222,128,0.45)",
    "--shadow-xl": "0 0 20px rgba(74,222,128,0.55)",
    "--motion-fast": "150ms",
    "--motion-normal": "200ms",
    "--motion-slow": "240ms",
    "--motion-easing": "ease-out",
    "--border-width-thin": "1px",
    "--border-width-normal": "2px",
    "--backdrop-blur": "0px",
    "--dv-chart-panel-bg": "transparent",
    "--dv-chart-panel-padding": "0",
    "--dv-chart-panel-border": "none",
    "--dv-chart-panel-radius": "0",
    "--dv-chart-plot-bg": "color-mix(in srgb, var(--color-text-primary) 15%, transparent)",
    "--dv-chart-grid-stroke": "rgba(74,222,128,0.08)",
    "--dv-chart-grid-dash": "2 8",
    "--dv-chart-axis-line": "#14532D",
    "--dv-chart-axis-tick-stroke": "#14532D",
    "--dv-chart-tick-label": "#86EFAC",
    "--dv-chart-axis-title": "#ECFDF5",
    "--dv-chart-legend-text": "#A7F3D0",
    "--dv-chart-legend-inactive": "rgba(167,243,208,0.35)",
    "--dv-chart-tooltip-bg": "#0B1F14",
    "--dv-chart-tooltip-border": "rgba(74,222,128,0.5)",
    "--dv-chart-tooltip-fg": "#ECFDF5",
    "--dv-chart-label-line": "rgba(167,243,208,0.5)",
    "--dv-chart-reference-stroke": "#FACC15",
    "--kpi-bg-from": "#052E16",
    "--kpi-bg-to": "#0F2918",
    "--kpi-text-primary": "#ECFDF5",
    "--kpi-text-secondary": "rgba(236,253,245,0.72)",
    "--kpi-text-muted": "rgba(236,253,245,0.42)",
    "--kpi-glow-base": "var(--color-primary)"
  },
  "chartPalette": ["#4ADE80", "#2DD4BF", "#22C55E", "#38BDF8", "#FACC15", "#F87171"],
  "raw": {
    "color": {
      "primary": { "name": "翠绿主强调", "hex": "#4ADE80", "usage": "主数据线、选中态、发光勾边" },
      "secondary": [
        { "name": "主色悬停", "hex": "#86EFAC", "usage": "交互高亮" },
        { "name": "青绿辅色", "hex": "#2DD4BF", "usage": "次级高亮、图例次要系列" },
        { "name": "香槟金", "hex": "#D4A855", "usage": "环形指标、金属高亮" }
      ],
      "accent": [],
      "surface": [
        { "name": "主背景", "hex": "#030712", "usage": "整屏最深底" },
        { "name": "模块衬底", "hex": "#0B1F14", "usage": "顶栏、模块" },
        { "name": "次级表面", "hex": "#132A1F", "usage": "hover/选中块" },
        { "name": "弱衬", "hex": "#1F3D2E", "usage": "分割、图表弱底" }
      ],
      "text": [
        { "name": "主文案", "hex": "#ECFDF5", "usage": "标题、数值" },
        { "name": "次级文案", "hex": "rgba(236,253,245,0.72)", "usage": "次要文字" },
        { "name": "弱化文案", "hex": "rgba(236,253,245,0.42)", "usage": "辅助、占位" },
        { "name": "反色文案", "hex": "#030712", "usage": "主色实心按钮上" }
      ],
      "border": [
        { "name": "边框", "hex": "rgba(74,222,128,0.22)", "usage": "模块分割" },
        { "name": "强边框", "hex": "rgba(74,222,128,0.55)", "usage": "强调描边" }
      ],
      "semantic": {
        "success": { "name": "成功", "hex": "#22C55E", "usage": "正常态" },
        "warning": { "name": "警告", "hex": "#FACC15", "usage": "预警" },
        "danger": { "name": "危险", "hex": "#F87171", "usage": "严重告警" },
        "info": { "name": "信息", "hex": "#38BDF8", "usage": "提示" },
        "grid": { "name": "网格", "hex": "rgba(74,222,128,0.06)", "usage": "图表网格" }
      }
    },
    "typography": {
      "fontFamily": {
        "display": "\"Rajdhani\",\"Bahnschrift\",\"DIN Alternate\",system-ui,sans-serif",
        "body": "system-ui,\"Segoe UI\",\"PingFang SC\",sans-serif",
        "mono": "ui-monospace,\"JetBrains Mono\",\"Fira Code\",monospace"
      },
      "scale": [
        { "size": "12px", "usage": "xs" },
        { "size": "14px", "usage": "sm" },
        { "size": "16px", "usage": "md" },
        { "size": "18px", "usage": "lg" },
        { "size": "22px", "usage": "xl" },
        { "size": "28px", "usage": "2xl" },
        { "size": "34px", "usage": "3xl" }
      ],
      "weights": [
        { "weight": 400, "name": "regular" },
        { "weight": 500, "name": "medium" },
        { "weight": 600, "name": "semibold" },
        { "weight": 700, "name": "bold" }
      ]
    },
    "spacing": { "baseUnit": "8px", "scale": ["8px", "12px", "16px", "24px", "32px", "48px", "64px", "96px", "128px"] },
    "radius": { "sm": "4px", "md": "6px", "lg": "8px", "xl": "12px", "pill": "9999px" },
    "shadow": {
      "sm": "0 0 2px rgba(74,222,128,0.4)",
      "md": "0 0 6px rgba(74,222,128,0.35)",
      "lg": "0 0 12px rgba(74,222,128,0.45)",
      "xl": "0 0 20px rgba(74,222,128,0.55)"
    },
    "motion": { "fast": "150ms", "normal": "200ms", "slow": "240ms", "easing": "ease-out" },
    "components": {
      "button": { "background": "var(--color-surface-2)", "border": "var(--color-border)", "active": "var(--color-primary)" },
      "card": { "background": "var(--color-surface)", "border": "var(--color-border)", "radius": "var(--radius-lg)" },
      "input": { "background": "var(--color-surface-2)", "border": "var(--color-border-strong)", "focus": "var(--color-primary)" },
      "navigation": { "tab": "primary 指示条" }
    }
  }
}
