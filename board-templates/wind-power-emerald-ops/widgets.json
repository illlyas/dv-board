          "field": "industry_avg_hours",
          "label": "行业平均发电小时",
          "color": "var(--color-accent-gold)"
        }
      ],
      "showLegend": true,
      "showGrid": true,
      "smooth": true,
      "area": true,
      "showPoints": false,
      "lineWidth": 3,
      "colorScheme": [
        "var(--color-primary)",
        "var(--color-accent-gold)"
      ],
      "gridColor": "var(--dv-chart-grid-stroke)",
      "axisColor": "var(--dv-chart-axis-line)",
      "axisTextColor": "var(--dv-chart-tick-label)",
      "legendTextColor": "var(--dv-chart-legend-text)",
      "tooltipBackgroundColor": "var(--dv-chart-tooltip-bg)",
      "tooltipTextColor": "var(--dv-chart-tooltip-fg)",
      "textColor": "var(--color-text-muted)",
      "echartsOptionOverrides": {
        "animationDuration": 600,
        "yAxis": {
          "min": 0,
          "max": 250,
          "interval": 125
        },
        "series": [
          {
            "name": "等效利用小时",
            "type": "line",
            "smooth": true,
            "showSymbol": false,
            "lineStyle": {
              "width": 3,
              "color": "var(--color-primary)",
              "shadowColor": "var(--color-primary-alpha-85)",
              "shadowBlur": 12
            },
            "itemStyle": {
              "color": "var(--color-primary)"
            },
            "areaStyle": {
              "opacity": 1,
              "color": {
                "type": "linear",
                "x": 0,
                "y": 0,
                "x2": 0,
                "y2": 1,
                "colorStops": [
                  {
                    "offset": 0,
                    "color": "var(--color-primary-alpha-10)"
                  },
                  {
                    "offset": 1,
                    "color": "transparent"
                  }
                ]
              }
            }
          },
          {
            "name": "行业平均发电小时",
            "type": "line",
            "smooth": true,
            "showSymbol": false,
            "lineStyle": {
              "width": 3,
              "color": "var(--color-accent-gold)",
              "shadowColor": "var(--color-accent-gold-alpha-75)",
              "shadowBlur": 10
            },
            "itemStyle": {
              "color": "var(--color-accent-gold)"
            },
            "areaStyle": {
              "opacity": 1,
              "color": {
                "type": "linear",
                "x": 0,
                "y": 0,
                "x2": 0,
                "y2": 1,
                "colorStops": [
                  {
                    "offset": 0,
                    "color": "var(--color-accent-gold-alpha-10)"
                  },
                  {
                    "offset": 1,
