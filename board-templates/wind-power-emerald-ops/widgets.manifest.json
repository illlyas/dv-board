{
  "templateId": "wind-power-emerald-ops",
  "description": "模板私有展示组件在 dashboard.jsx 内实现；平台 Widget 见 widgets.json；PanelShell 标题见 slots.schema.json panelHeaders（props.panelHeaders）。",
  "components": [
    {
      "importName": "BoardHeaderChrome",
      "file": "dashboard.jsx",
      "role": "顶栏天气/城市（内部 useStoreData）"
    },
    {
      "importName": "BoardClock",
      "file": "dashboard.jsx",
      "role": "顶栏实时时钟"
    },
    {
      "importName": "P0GenProgressPanel",
      "file": "dashboard.jsx",
      "role": "左栏·目标完成情况"
    },
    {
      "importName": "P0ProductionCapacityPanel",
      "file": "dashboard.jsx",
      "role": "左栏·生产基地与装机容量"
    },
    {
      "importName": "P1RealtimePrimaryPanel",
      "file": "dashboard.jsx",
      "role": "左栏 P1·实测序列"
    },
    {
      "importName": "P1RealtimeSecondaryPanel",
      "file": "dashboard.jsx",
      "role": "左栏 P1·监测序列"
    },
    {
      "importName": "CenterGeoMapPanel",
      "file": "dashboard.jsx",
      "role": "中栏地图与省份信息卡"
    },
    {
      "importName": "P0TransitLogisticsPanel",
      "file": "dashboard.jsx",
      "role": "右栏·智慧物流"
    },
    {
      "importName": "P0MaintenancePanel",
      "file": "dashboard.jsx",
      "role": "右栏·运维"
    },
    {
      "importName": "P1AlarmListTablePanel",
      "file": "dashboard.jsx",
      "role": "右栏 P1·实时告警列表表"
    },
    {
      "importName": "P1DeviceLogTablePanel",
      "file": "dashboard.jsx",
      "role": "右栏 P1·设备日志表"
    },
    {
      "importName": "PanelShell",
      "file": "dashboard.jsx",
      "role": "布局壳",
      "props": {
        "headerTitle": "string — 面板标题",
        "children": "ReactNode — 内容区"
      }
    },
    {
      "importName": "KpiGlowBar",
      "file": "dashboard.jsx",
      "role": "横向 KPI + 进度发光条",
      "props": {
        "label": "string",
        "value": "number | string",
        "unit": "string，可选",
        "max": "number — 用于百分比",
        "dir": "\"up\" | \"down\"",
        "iconId": "BoardPresetIcon id，可选",
        "tone": "\"success\" | \"warning\""
      }
    },
    {
      "importName": "KpiPercentStat",
      "file": "dashboard.jsx",
      "role": "环形百分比 + 当前/总量",
      "props": {
        "tone": "\"success\" | \"warning\"",
        "label": "string",
        "current": "number",
        "total": "number"
      }
    },
    {
      "importName": "FramedStat",
      "file": "dashboard.jsx",
      "role": "带框 KPI 摘要",
      "props": {
        "tone": "\"success\" | \"warning\"",
        "iconId": "string",
        "title": "string",
        "value": "string",
        "unit": "string"
      }
    },
    {
      "importName": "KpiGaugeStat",
      "file": "dashboard.jsx",
      "role": "半环仪表 + 数值",
      "props": {
        "iconId": "string",
        "title": "string",
        "value": "string | number",
        "unit": "string",
        "tone": "\"success\" | \"warning\""
      }
    },
    {
      "importName": "RingStat",
      "file": "dashboard.jsx",
      "role": "环形高亮计数块",
      "props": {
        "label": "string",
        "value": "string",
        "unit": "string，可选",
        "tone": "\"success\" | \"warning\" | \"neutral\""
      }
    }
  ],
  "platformWidgetsUsed": [
    "KPI",
    "LineChart",
    "BarChart",
    "DonutChart",
    "GeoMap",
    "Table",
    "Title（header 内 data-widget）"
  ],
  "widgetsConfigFile": "widgets.json"
}
