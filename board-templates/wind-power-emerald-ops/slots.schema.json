{
  "version": 1,
  "templateId": "wind-power-emerald-ops",
  "canvas": { "width": 2560, "height": 900 },
  "purpose": "AI 填空单一入口：描述页面、区域、数据插槽与配置块；生成或改写大屏时须保持布局骨架与 slotId 集合一致，仅替换业务语义、数据与 vi-tokens。",
  "invariants": [
    "dashboard.jsx 保持三栏 grid + header(72) + footer(56) + 2560×900 根容器；分页仅两页 currentPage 0/1。",
    "平台内置组件通过 Widget config={widgets.xxx} 引用；模板私有组件仅允许 components/ 下已实现且在 widgets.manifest.json 列出的 import。",
    "凡含 dataSlotId 的 Widget，必须在 dashboard.store.json 对应 page.components 中存在同 slotId 的条目。",
    "useStoreData(\"p*.config.*\") 的配置块须在 store 中存在 slotId 与路径一致（见各 slot 的 storePath）。"
  ],
  "files": {
    "structure": "dashboard.jsx + widgets.json（props.widgets）；panelHeaders / chrome 经 props 注入分区标题、Geo 图例与 Footer",
    "data": "dashboard.store.json",
    "visual": "vi-tokens.json",
    "privateComponents": "widgets.manifest.json"
  },
  "chrome": {
    "mapLegend": {
      "on": "● 设施点位",
      "off": "○ 监测点位",
      "fill": "template-fill 顶层 mapLegend 或 slots['p0.config.province_data'].provinceData.mapLegend（装配时合并入 store 与 slots.schema.chrome）"
    },
    "footerNav": [
      { "pageIndex": 0, "label": "总览" },
      { "pageIndex": 1, "label": "实时监控" }
    ],
    "fill": "template-fill 顶层 footerNav: [{ pageIndex, label }] → 写入 slots.schema.chrome.footerNav 与 pages[].label"
  },
  "panelHeaders": {
    "gen_completion": "目标完成情况",
    "production_base": "生产基地项目情况",
    "capacity": "装机容量",
    "realtime_primary": "实时监测（主）",
    "realtime_secondary": "实时监测（次）",
    "logistics": "业务系统智慧物流",
    "maintenance": "业务系统运维",
    "alarm_list": "实时告警列表",
    "device_log": "设备运行日志"
  },
  "panelShellBindings": [
    { "key": "gen_completion", "component": "P0GenProgressPanel", "pageIndex": 0, "region": "leftPanels" },
    { "key": "production_base", "component": "P0ProductionCapacityPanel", "pageIndex": 0, "region": "leftPanels" },
    { "key": "capacity", "component": "P0ProductionCapacityPanel", "pageIndex": 0, "region": "leftPanels" },
    { "key": "realtime_primary", "component": "P1RealtimePrimaryPanel", "pageIndex": 1, "region": "leftPanels" },
    { "key": "realtime_secondary", "component": "P1RealtimeSecondaryPanel", "pageIndex": 1, "region": "leftPanels" },
    { "key": "logistics", "component": "P0TransitLogisticsPanel", "pageIndex": 0, "region": "rightPanels" },
    { "key": "maintenance", "component": "P0MaintenancePanel", "pageIndex": 0, "region": "rightPanels" },
    { "key": "alarm_list", "component": "P1AlarmListTablePanel", "pageIndex": 1, "region": "rightPanels" },
    { "key": "device_log", "component": "P1DeviceLogTablePanel", "pageIndex": 1, "region": "rightPanels" }
  ],
  "pages": [
    {
      "pageIndex": 0,
      "label": "总览",
      "layout": {
        "header": ["天气文案区", "主标题「运营监控中心」", "日期时间"],
        "centerTop": ["5 个 KPI 横排（Widget）"],
        "centerMain": ["GeoMap 中国 + 省份信息卡 + 图例"],
        "leftPanels": ["目标完成情况", "生产基地项目情况 + 装机容量"],
        "rightPanels": ["业务系统智慧物流", "业务系统运维"]
      }
    },
    {
      "pageIndex": 1,
      "label": "实时监控",
      "layout": {
        "leftPanels": ["实时监测（主）（KpiGlowBar + 折线种子 store + 运行时追加）", "实时监测（次）"],
        "center": ["与 page0 共用中栏地图与顶 KPI"],
        "rightPanels": ["实时告警列表 Table", "设备运行日志 Table"]
      }
    }
  ],
  "slots": [
    {
      "slotId": "p0.kpi.hero_01",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_hero_01",
      "fill": { "titlesUnits": "可改", "dataKey": "须与 store payload 字段一致" }
    },
    {
      "slotId": "p0.kpi.hero_02",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_hero_02"
    },
    {
      "slotId": "p0.kpi.availability",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_avail"
    },
    {
      "slotId": "p0.kpi.emission",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_emission"
    },
    {
      "slotId": "p0.kpi.hero_05",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_hero_05"
    },
    {
      "slotId": "p0.kpi.side_01",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_side_01"
    },
    {
      "slotId": "p0.kpi.side_02",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_side_02"
    },
    {
      "slotId": "p0.kpi.side_03",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_side_03"
    },
    {
      "slotId": "p0.chart.hours_trend",
      "pageIndex": 0,
      "surface": "Widget<LineChart>",
      "widgetKey": "p0_chart_hours",
      "fill": {
        "seriesSemantics": "可改系列名与 echartsOptionOverrides，须保持 dataKey 指向 store 中数组",
        "templateFill": "seedSeriesRows 替换 store 折线数据行"
      }
    },
    {
      "slotId": "p0.kpi.capacity_rate",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_capacity"
    },
    {
      "slotId": "p0.kpi.plan_rate",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_plan"
    },
    {
      "slotId": "p0.chart.capacity",
      "pageIndex": 0,
      "surface": "Widget<BarChart>",
      "widgetKey": "p0_chart_capacity",
      "fill": "template-fill：seedSeriesRows 替换柱状序列数据"
    },
    {
      "slotId": "p0.kpi.status_01",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_status_01"
    },
    {
      "slotId": "p0.kpi.status_02",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_status_02"
    },
    {
      "slotId": "p0.chart.device_donut",
      "pageIndex": 0,
      "surface": "Widget<DonutChart>",
      "widgetKey": "p0_chart_device",
      "fill": "template-fill：seedSeriesRows 替换环形图 name/value 行"
    },
    {
      "slotId": "p0.kpi.util_hours",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_util"
    },
    {
      "slotId": "p0.kpi.mldt",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_mldt"
    },
    {
      "slotId": "p0.kpi.mttr",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_mttr"
    },
    {
      "slotId": "p0.config.gen_progress",
      "pageIndex": 0,
      "kind": "config",
      "storePath": "pages[0].components 中 slotId 匹配",
      "useStoreData": "p0.config.gen_progress",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p0.config.gen_progress\"].configValue 整对象替换 payload.value（含 items 数组）"
    },
    {
      "slotId": "p0.config.production_base",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.production_base",
      "dataShape": "{ capacity:{label,current,total}, plan:{label,current,total}, capacityBars:KpiGlowBar[], planBars:KpiGlowBar[] }",
      "notes": "capacityBars/planBars 每项 { label,value,max,unit,dir? }；禁止对 bars 使用 current/total",
      "fill": "template-fill：configValue 替换 payload.value（capacity/plan 用 current+total；bars 用 value+max）"
    },
    {
      "slotId": "p0.config.transit_summary",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.transit_summary",
      "dataShape": "{ running: FramedStatProps, abnormal: FramedStatProps }",
      "fill": "template-fill：configValue 替换 payload.value"
    },
    {
      "slotId": "p0.config.daily_orders",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.daily_orders",
      "dataShape": "{ title: string, bars: KpiGlowBarProps[] }",
      "fill": "template-fill：configValue 替换 payload.value"
    },
    {
      "slotId": "p0.config.maintenance_metrics",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.maintenance_metrics",
      "dataShape": "{ items: KpiGaugeStatProps[] }；每项 { iconId, title, value, unit, tone }",
      "fill": "template-fill：configValue 替换 payload.value（items 须用 title 作指标名，勿用 label）"
    },
    {
      "slotId": "p0.config.work_orders",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.work_orders",
      "dataShape": "{ items: RingStatProps[] }",
      "fill": "template-fill：configValue 替换 payload.value（items）"
    },
    {
      "slotId": "p0.config.province_data",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.province_data",
      "dataShape": "{ defaultProvince, provinces, header?, mapLegend:{on,off}, regionCard?, modes?:{ off:{ provinces?, regionCard? } } }；mapLegend 为 GeoMap 左下角按钮文案（必填，语义对齐 Story）；provinces 键为省级全称。template-fill：provinceData 整对象或顶层 mapLegend",
      "notes": "mapLegend.on=设施/业务层按钮；mapLegend.off=监测层按钮（与 map_scatter.off 数据层对应）"
    },
    {
      "slotId": "p0.config.map_scatter",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.map_scatter",
      "dataShape": "{ on: ScatterRow[], off: ScatterRow[] } 或 ScatterRow[]（视为 on）；ScatterRow={ name, value:[lng,lat,size] }",
      "fill": "template-fill：seedSeriesRows 替换 payload.value（双模式散点或纯 on 数组）"
    },
    {
      "slotId": "p1.chart.realtime_primary",
      "pageIndex": 1,
      "surface": "Widget<LineChart> + staticData 运行时覆盖",
      "widgetKey": "p1_chart_realtime_primary",
      "notes": "template-fill：subtitle/xAxisLabel/yAxisLabels（如实测序列、计划序列）；曲线数据来自 p1.chart.realtime_primary_seed 的 seedSeriesRows 写入 store 后由 staticData 展示"
    },
    {
      "slotId": "p1.chart.realtime_secondary",
      "pageIndex": 1,
      "surface": "Widget<LineChart> + staticData",
      "widgetKey": "p1_chart_realtime_secondary",
      "notes": "template-fill：subtitle/xAxisLabel/yAxisLabels；种子 p1.chart.realtime_secondary_seed 的 seedSeriesRows"
    },
    {
      "slotId": "p1.chart.alarm_bar",
      "pageIndex": 1,
      "surface": "Widget<BarChart>",
      "widgetKey": "p1_chart_alarm_bar"
    },
    {
      "slotId": "p1.chart.device_status",
      "pageIndex": 1,
      "surface": "Widget<DonutChart>",
      "widgetKey": "p1_chart_device_status"
    },
    {
      "slotId": "p1.config.realtime_primary_kpi",
      "pageIndex": 1,
      "kind": "config",
      "useStoreData": "p1.config.realtime_primary_kpi",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p1.config.realtime_primary_kpi\"].kpiGlowItems → 覆盖 store payload.value.items"
    },
    {
      "slotId": "p1.config.realtime_secondary_kpi",
      "pageIndex": 1,
      "kind": "config",
      "useStoreData": "p1.config.realtime_secondary_kpi",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p1.config.realtime_secondary_kpi\"].kpiGlowItems"
    },
    {
      "slotId": "p1.chart.realtime_primary_seed",
      "pageIndex": 1,
      "kind": "seed",
      "useStoreData": "p1.chart.realtime_primary_seed",
      "dataShape": "seriesRows 行键须与 p1.chart.realtime_primary 对应 widget 的 xAxis.field + yAxis[].field 完全一致（由 widgets-fill 决定，勿写死 time/value/series_secondary）",
      "fill": "template-fill：slots[\"p1.chart.realtime_primary_seed\"].seedSeriesRows 整表替换 payload.value"
    },
    {
      "slotId": "p1.chart.realtime_secondary_seed",
      "pageIndex": 1,
      "kind": "seed",
      "useStoreData": "p1.chart.realtime_secondary_seed",
      "dataShape": "seriesRows 行键须与 p1.chart.realtime_secondary 对应 widget 的 xAxis.field + yAxis[].field 完全一致",
      "fill": "template-fill：slots[\"p1.chart.realtime_secondary_seed\"].seedSeriesRows"
    },
    {
      "slotId": "p1.table.alarm_list",
      "pageIndex": 1,
      "surface": "Widget<Table>",
      "widgetKey": "p1_table_alarm_list",
      "dataKey": "alarm_list",
      "notes": "template-fill：slots[\"p1.table.alarm_list\"].tableRows 整表替换 store；每行字段 triggered_at,name,metric,trend"
    },
    {
      "slotId": "p1.table.device_log",
      "pageIndex": 1,
      "surface": "Widget<Table>",
      "dataKey": "device_log_list",
      "notes": "template-fill：slots[\"p1.table.device_log\"].tableRows 整表替换 store；每行字段 triggered_at,department,name,value"
    }
  ]
}
