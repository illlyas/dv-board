{
  "version": 1,
  "templateId": "wind-power-emerald-ops",
  "canvas": { "width": 2560, "height": 900 },
  "purpose": "AI 填空单一入口：描述页面、区域、数据插槽与配置块；生成或改写大屏时须保持布局骨架与 slotId 集合一致，仅替换业务语义、数据与 vi-tokens。",
  "invariants": [
    "dashboard.jsx 保持三栏 grid + header(72) + footer(56) + 2560×900 根容器；分页仅两页 currentPage 0/1。",
    "平台内置组件通过 Widget config={widgets.xxx} 引用；模板私有组件仅允许 components/ 下已实现且在 widgets.manifest.json 列出的 import。",
    "凡含 dataSlotId 的 Widget，必须在 dashboard.store.json 对应 page.components 中存在同 slotId 的条目。",
    "useStoreData(\"p*.config.*\") 的配置块须在 store 中存在 slotId 与路径一致（见各 slot 的 storePath）。"
  ],
  "files": {
    "structure": "dashboard.jsx",
    "data": "dashboard.store.json",
    "visual": "vi-tokens.json",
    "privateComponents": "widgets.manifest.json"
  },
  "pages": [
    {
      "pageIndex": 0,
      "label": "总览",
      "layout": {
        "header": ["天气文案区", "主标题「风电智慧运营」", "日期时间"],
        "centerTop": ["5 个 KPI 横排（Widget）"],
        "centerMain": ["GeoMap 中国 + 省份信息卡 + 图例"],
        "leftPanels": ["发电量完成情况", "生产基地项目情况 + 装机容量"],
        "rightPanels": ["业务系统智慧物流", "业务系统运维"]
      }
    },
    {
      "pageIndex": 1,
      "label": "实时监控",
      "layout": {
        "leftPanels": ["实时功率监控（KpiGlowBar + 折线种子 store + 运行时追加）", "风速实时监测"],
        "center": ["与 page0 共用中栏地图与顶 KPI"],
        "rightPanels": ["实时告警列表 Table", "设备运行日志 Table"]
      }
    }
  ],
  "slots": [
    {
      "slotId": "p0.kpi.wind_farms",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_farms",
      "fill": { "titlesUnits": "可改", "dataKey": "须与 store payload 字段一致" }
    },
    {
      "slotId": "p0.kpi.wind_units",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_units"
    },
    {
      "slotId": "p0.kpi.availability",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_avail"
    },
    {
      "slotId": "p0.kpi.emission",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_emission"
    },
    {
      "slotId": "p0.kpi.clean_gen",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_clean"
    },
    {
      "slotId": "p0.kpi.gen_year",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_gen_year"
    },
    {
      "slotId": "p0.kpi.gen_month",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_gen_month"
    },
    {
      "slotId": "p0.kpi.gen_day",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_gen_day"
    },
    {
      "slotId": "p0.chart.hours_trend",
      "pageIndex": 0,
      "surface": "Widget<LineChart>",
      "widgetKey": "p0_chart_hours",
      "fill": {
        "seriesSemantics": "可改系列名与 echartsOptionOverrides，须保持 dataKey 指向 store 中数组",
        "templateFill": "seedSeriesRows 替换 store 折线数据行"
      }
    },
    {
      "slotId": "p0.kpi.capacity_rate",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_capacity"
    },
    {
      "slotId": "p0.kpi.plan_rate",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_plan"
    },
    {
      "slotId": "p0.chart.capacity",
      "pageIndex": 0,
      "surface": "Widget<BarChart>",
      "widgetKey": "p0_chart_capacity",
      "fill": "template-fill：seedSeriesRows 替换柱状序列数据"
    },
    {
      "slotId": "p0.kpi.running_orders",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_running"
    },
    {
      "slotId": "p0.kpi.abnormal_orders",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_abnormal"
    },
    {
      "slotId": "p0.chart.device_donut",
      "pageIndex": 0,
      "surface": "Widget<DonutChart>",
      "widgetKey": "p0_chart_device",
      "fill": "template-fill：seedSeriesRows 替换环形图 name/value 行"
    },
    {
      "slotId": "p0.kpi.util_hours",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_util"
    },
    {
      "slotId": "p0.kpi.mldt",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_mldt"
    },
    {
      "slotId": "p0.kpi.mttr",
      "pageIndex": 0,
      "surface": "Widget<KPI>",
      "widgetKey": "p0_kpi_mttr"
    },
    {
      "slotId": "p0.config.gen_progress",
      "pageIndex": 0,
      "kind": "config",
      "storePath": "pages[0].components 中 slotId 匹配",
      "useStoreData": "p0.config.gen_progress",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p0.config.gen_progress\"].configValue 整对象替换 payload.value（含 items 数组）"
    },
    {
      "slotId": "p0.config.production_base",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.production_base",
      "dataShape": "{ capacity, capacityBars[], plan, planBars[] }",
      "fill": "template-fill：configValue 替换 payload.value（capacity、capacityBars、plan、planBars）"
    },
    {
      "slotId": "p0.config.transit_summary",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.transit_summary",
      "dataShape": "{ running: FramedStatProps, abnormal: FramedStatProps }",
      "fill": "template-fill：configValue 替换 payload.value"
    },
    {
      "slotId": "p0.config.daily_orders",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.daily_orders",
      "dataShape": "{ title: string, bars: KpiGlowBarProps[] }",
      "fill": "template-fill：configValue 替换 payload.value"
    },
    {
      "slotId": "p0.config.maintenance_metrics",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.maintenance_metrics",
      "dataShape": "{ items: KpiGaugeStatProps[] }",
      "fill": "template-fill：configValue 替换 payload.value（items）"
    },
    {
      "slotId": "p0.config.work_orders",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.work_orders",
      "dataShape": "{ items: RingStatProps[] }",
      "fill": "template-fill：configValue 替换 payload.value（items）"
    },
    {
      "slotId": "p0.config.province_data",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.province_data",
      "dataShape": "{ defaultProvince, provinces, header?, mapLegend?, regionCard? }；regionCard 含指标文案与 logsColumnLabel（设备日志表头）。template-fill：slots[\"p0.config.province_data\"].provinceData 与 payload.value 合并，provinces 按键与模板合并"
    },
    {
      "slotId": "p0.config.map_scatter",
      "pageIndex": 0,
      "kind": "config",
      "useStoreData": "p0.config.map_scatter",
      "dataShape": "GeoMap scatter 点列表；结构须符合 GeoMap 组件约定",
      "fill": "template-fill：seedSeriesRows 整表替换 payload.value（name + value:[lng,lat,size]）"
    },
    {
      "slotId": "p1.chart.power_realtime",
      "pageIndex": 1,
      "surface": "Widget<LineChart> + staticData 运行时覆盖",
      "widgetKey": "p1_chart_power_realtime",
      "notes": "template-fill：subtitle/xAxisLabel/yAxisLabels（如实时功率、计划功率）；曲线数据来自 p1.chart.power_realtime_seed 的 seedSeriesRows 写入 store 后由 staticData 展示"
    },
    {
      "slotId": "p1.chart.wind_speed",
      "pageIndex": 1,
      "surface": "Widget<LineChart> + staticData",
      "widgetKey": "p1_chart_wind_speed",
      "notes": "template-fill：subtitle/xAxisLabel/yAxisLabels；种子 p1.chart.wind_speed_seed 的 seedSeriesRows"
    },
    {
      "slotId": "p1.chart.alarm_bar",
      "pageIndex": 1,
      "surface": "Widget<BarChart>",
      "widgetKey": "p1_chart_alarm_bar"
    },
    {
      "slotId": "p1.chart.device_status",
      "pageIndex": 1,
      "surface": "Widget<DonutChart>",
      "widgetKey": "p1_chart_device_status"
    },
    {
      "slotId": "p1.config.power_kpi",
      "pageIndex": 1,
      "kind": "config",
      "useStoreData": "p1.config.power_kpi",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p1.config.power_kpi\"].kpiGlowItems → 覆盖 store payload.value.items"
    },
    {
      "slotId": "p1.config.wind_kpi",
      "pageIndex": 1,
      "kind": "config",
      "useStoreData": "p1.config.wind_kpi",
      "dataShape": "{ items: KpiGlowBarProps[] }",
      "fill": "template-fill：slots[\"p1.config.wind_kpi\"].kpiGlowItems"
    },
    {
      "slotId": "p1.chart.power_realtime_seed",
      "pageIndex": 1,
      "kind": "seed",
      "useStoreData": "p1.chart.power_realtime_seed",
      "dataShape": "Array<{ time: string, value: number, plan_power: number }>（历史 orders 键会在装配时迁移为 plan_power）",
      "fill": "template-fill：slots[\"p1.chart.power_realtime_seed\"].seedSeriesRows 整表替换 payload.value"
    },
    {
      "slotId": "p1.chart.wind_speed_seed",
      "pageIndex": 1,
      "kind": "seed",
      "useStoreData": "p1.chart.wind_speed_seed",
      "dataShape": "Array<{ time: string, value: number }>",
      "fill": "template-fill：slots[\"p1.chart.wind_speed_seed\"].seedSeriesRows"
    },
    {
      "slotId": "p1.table.alarm_list",
      "pageIndex": 1,
      "surface": "Widget<Table>",
      "dataKey": "alarm_list",
      "notes": "template-fill：slots[\"p1.table.alarm_list\"].tableRows 整表替换 store；每行字段 triggered_at,name,metric,trend"
    },
    {
      "slotId": "p1.table.device_log",
      "pageIndex": 1,
      "surface": "Widget<Table>",
      "dataKey": "device_log_list",
      "notes": "template-fill：slots[\"p1.table.device_log\"].tableRows 整表替换 store；每行字段 triggered_at,department,name,value"
    }
  ]
}
