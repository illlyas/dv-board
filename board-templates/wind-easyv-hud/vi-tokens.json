{
  "mode": "dark",
  "cssVariables": {
    "--color-bg": "#030712",
    "--color-surface": "#0a1628",
    "--color-surface-2": "#0f2238",
    "--color-muted": "#1a2f45",
    "--color-primary": "#4ADE80",
    "--color-primary-hover": "#86EFAC",
    "--color-accent": "#FBBF24",
    "--color-success": "#22C55E",
    "--color-warning": "#FACC15",
    "--color-danger": "#FB923C",
    "--color-info": "#38BDF8",
    "--color-text-primary": "#ECFEFF",
    "--color-text-secondary": "#94A3B8",
    "--color-text-muted": "#64748B",
    "--color-text-inverse": "#022C22",
    "--color-border": "rgba(148,163,184,0.22)",
    "--color-border-strong": "rgba(74,222,128,0.5)",
    "--color-grid": "rgba(74,222,128,0.1)",
    "--dv-chart-panel-bg": "color-mix(in srgb, var(--color-muted) 6%, transparent)",
    "--dv-chart-panel-padding": "0",
    "--dv-chart-panel-border": "none",
    "--dv-chart-panel-radius": "0",
    "--dv-chart-plot-bg": "color-mix(in srgb, var(--color-text-primary) 12%, transparent)",
    "--color-overlay": "rgba(0,0,0,0.65)",
    "--font-display": "\"DIN Alternate\",\"Roboto Condensed\",system-ui,sans-serif",
    "--font-body": "system-ui,\"Segoe UI\",sans-serif",
    "--font-mono": "ui-monospace,\"JetBrains Mono\",monospace",
    "--font-size-xs": "12px",
    "--font-size-sm": "14px",
    "--font-size-md": "16px",
    "--font-size-lg": "18px",
    "--font-size-xl": "22px",
    "--font-size-2xl": "26px",
    "--font-size-3xl": "32px",
    "--font-weight-regular": "400",
    "--font-weight-medium": "500",
    "--font-weight-semibold": "600",
    "--font-weight-bold": "700",
    "--line-height-tight": "1.15",
    "--line-height-normal": "1.45",
    "--line-height-relaxed": "1.55",
    "--letter-spacing-tight": "-0.02em",
    "--letter-spacing-normal": "0",
    "--letter-spacing-wide": "0.05em",
    "--space-1": "8px",
    "--space-2": "12px",
    "--space-3": "16px",
    "--space-4": "24px",
    "--space-5": "32px",
    "--space-6": "48px",
    "--space-8": "64px",
    "--space-10": "96px",
    "--space-12": "128px",
    "--radius-sm": "4px",
    "--radius-md": "6px",
    "--radius-lg": "8px",
    "--radius-xl": "12px",
    "--radius-pill": "9999px",
    "--shadow-sm": "0 0 2px rgba(74,222,128,0.45)",
    "--shadow-md": "0 0 4px rgba(74,222,128,0.45)",
    "--shadow-lg": "0 0 8px rgba(74,222,128,0.5)",
    "--shadow-xl": "0 0 16px rgba(74,222,128,0.55)",
    "--motion-fast": "150ms",
    "--motion-normal": "200ms",
    "--motion-slow": "240ms",
    "--motion-easing": "ease-out",
    "--border-width-thin": "1px",
    "--border-width-normal": "2px",
    "--backdrop-blur": "0px",
    "--dv-chart-grid-stroke": "rgba(74,222,128,0.14)",
    "--dv-chart-grid-dash": "2 8",
    "--dv-chart-axis-line": "#64748B",
    "--dv-chart-axis-tick-stroke": "#64748B",
    "--dv-chart-tick-label": "#94A3B8",
    "--dv-chart-axis-title": "#ECFEFF",
    "--dv-chart-legend-text": "#94A3B8",
    "--dv-chart-legend-inactive": "rgba(148,163,184,0.4)",
    "--dv-chart-tooltip-bg": "#0a1628",
    "--dv-chart-tooltip-border": "rgba(74,222,128,0.45)",
    "--dv-chart-tooltip-fg": "#ECFEFF",
    "--dv-chart-label-line": "rgba(148,163,184,0.5)",
    "--dv-chart-reference-stroke": "#FB923C",
    "--kpi-bg-from": "#0c1a2e",
    "--kpi-bg-to": "#152a42",
    "--kpi-text-primary": "#ECFEFF",
    "--kpi-text-secondary": "rgba(255,255,255,0.72)",
    "--kpi-text-muted": "rgba(255,255,255,0.42)",
    "--kpi-glow-base": "var(--color-primary)"
  },
  "chartPalette": ["#4ADE80", "#FBBF24", "#38BDF8", "#A78BFA", "#FB923C", "#22D3EE"],
  "raw": {
    "color": {
      "primary": {
        "name": "主色",
        "hex": "#4ADE80",
        "usage": "风电主题强调、主数据线"
      },
      "secondary": [
        { "name": "主色悬停", "hex": "#86EFAC", "usage": "交互高亮" },
        { "name": "accent", "hex": "#FBBF24", "usage": "对比系列、告警强调" }
      ],
      "accent": [],
      "surface": [
        { "name": "主背景", "hex": "#030712", "usage": "整屏最深底" },
        { "name": "表面", "hex": "#0a1628", "usage": "顶栏与模块衬底" },
        { "name": "次级表面", "hex": "#0f2238", "usage": "hover 模块" },
        { "name": "弱衬", "hex": "#1a2f45", "usage": "图表弱底" }
      ],
      "text": [
        { "name": "主文案", "hex": "#ECFEFF", "usage": "标题数值" },
        { "name": "次级文案", "hex": "#94A3B8", "usage": "次要文字" },
        { "name": "弱化文案", "hex": "#64748B", "usage": "辅助" },
        { "name": "反色文案", "hex": "#022C22", "usage": "主色按钮上" }
      ],
      "border": [
        { "name": "边框", "hex": "rgba(148,163,184,0.22)", "usage": "分割" },
        { "name": "强边框", "hex": "rgba(74,222,128,0.5)", "usage": "强调" }
      ],
      "semantic": {
        "success": { "name": "成功", "hex": "#22C55E", "usage": "正向" },
        "warning": { "name": "警告", "hex": "#FACC15", "usage": "警示" },
        "danger": { "name": "危险", "hex": "#FB923C", "usage": "异常" },
        "info": { "name": "信息", "hex": "#38BDF8", "usage": "提示" },
        "grid": { "name": "网格线", "hex": "rgba(74,222,128,0.1)", "usage": "图表网格" }
      }
    },
    "typography": {
      "fontFamily": {
        "display": "\"DIN Alternate\",\"Roboto Condensed\",system-ui,sans-serif",
        "body": "system-ui,\"Segoe UI\",sans-serif",
        "mono": "ui-monospace,\"JetBrains Mono\",monospace"
      },
      "scale": [
        { "size": "12px", "usage": "xs" },
        { "size": "14px", "usage": "sm" },
        { "size": "16px", "usage": "md" },
        { "size": "18px", "usage": "lg" },
        { "size": "22px", "usage": "xl" },
        { "size": "26px", "usage": "2xl" },
        { "size": "32px", "usage": "3xl" }
      ],
      "weights": [
        { "weight": 400, "name": "regular" },
        { "weight": 500, "name": "medium" },
        { "weight": 600, "name": "semibold" },
        { "weight": 700, "name": "bold" }
      ]
    },
    "spacing": {
      "baseUnit": "8px",
      "scale": ["8px", "12px", "16px", "24px", "32px", "48px", "64px", "96px", "128px"]
    },
    "radius": {
      "sm": "4px",
      "md": "6px",
      "lg": "8px",
      "xl": "12px",
      "pill": "9999px"
    },
    "shadow": {
      "sm": "0 0 2px rgba(74,222,128,0.45)",
      "md": "0 0 4px rgba(74,222,128,0.45)",
      "lg": "0 0 8px rgba(74,222,128,0.5)",
      "xl": "0 0 16px rgba(74,222,128,0.55)"
    },
    "motion": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "240ms",
      "easing": "ease-out"
    },
    "components": {
      "button": {
        "background": "var(--color-surface-2) or transparent",
        "border": "var(--color-border)",
        "active": "var(--color-primary) fill or border"
      },
      "card": {
        "background": "var(--color-surface)",
        "border": "var(--color-border)",
        "radius": "var(--radius-lg, 8px)"
      },
      "input": {
        "background": "var(--color-surface-2)",
        "border": "var(--color-border-strong)",
        "focus": "var(--color-primary) glow"
      },
      "navigation": {
        "tab": "semi-transparent background, primary color selection"
      }
    }
  }
}
